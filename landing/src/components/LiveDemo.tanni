  }
<span class="text-gray-400">&lt;/script&gt;</span>

<span class="text-gray-400">&lt;template&gt;</span>
  <span class="text-rose-600">&lt;p&gt;</span>{{ <span class="text-amber-600">count</span>() }}<span class="text-rose-600">&lt;/p&gt;</span>
  <span class="text-rose-600">&lt;button</span> <span class="text-violet-600">@click</span>=<span class="text-emerald-600">"increment"</span><span class="text-rose-600">&gt;</span>+ 1<span class="text-rose-600">&lt;/button&gt;</span>
  <span class="text-rose-600">&lt;button</span> <span class="text-violet-600">@click</span>=<span class="text-emerald-600">"decrement"</span><span class="text-rose-600">&gt;</span>− 1<span class="text-rose-600">&lt;/button&gt;</span>
  <span class="text-rose-600">&lt;button</span> <span class="text-violet-600">@click</span>=<span class="text-emerald-600">"reset"</span><span class="text-rose-600">&gt;</span>Reset<span class="text-rose-600">&lt;/button&gt;</span>
<span class="text-gray-400">&lt;/template&gt;</span></code></pre>
        </div>

        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <div class="flex items-center gap-2 border-b border-gray-100 bg-gray-50 px-4 py-2.5">
            <span class="h-3 w-3 rounded-full bg-red-400"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
            <span class="h-3 w-3 rounded-full bg-green-400"></span>
            <span class="ml-2 text-xs font-medium text-gray-500">Compiled Output</span>
          </div>
          <pre class="overflow-x-auto p-4 text-[13px] leading-relaxed"><code class="text-gray-800"><span class="text-blue-600">import</span> { createSignal, <span class="text-amber-600">effect</span> }
  <span class="text-blue-600">from</span> <span class="text-emerald-600">'tannijs'</span>;

<span class="text-blue-600">export default function</span> <span class="text-amber-600">Counter</span>() {
  <span class="text-blue-600">const</span> [count, setCount] = <span class="text-amber-600">createSignal</span>(<span class="text-violet-600">0</span>);

  <span class="text-blue-600">function</span> <span class="text-amber-600">increment</span>() {
    <span class="text-amber-600">setCount</span>(<span class="text-gray-500">(c) =&gt;</span> c + <span class="text-violet-600">1</span>);
  }
  <span class="text-blue-600">function</span> <span class="text-amber-600">decrement</span>() {
    <span class="text-amber-600">setCount</span>(<span class="text-gray-500">(c) =&gt;</span> c - <span class="text-violet-600">1</span>);
  }
  <span class="text-blue-600">function</span> <span class="text-amber-600">reset</span>() {
    <span class="text-amber-600">setCount</span>(<span class="text-violet-600">0</span>);
  }

  <span class="text-blue-600">const</span> p = document.<span class="text-amber-600">createElement</span>(<span class="text-emerald-600">"p"</span>);
  <span class="text-amber-600">effect</span>(<span class="text-gray-500">() =&gt;</span> {
    p.textContent = <span class="text-amber-600">count</span>();
  });

  <span class="text-blue-600">const</span> btn1 = document.<span class="text-amber-600">createElement</span>(<span class="text-emerald-600">"button"</span>);
  btn1.textContent = <span class="text-emerald-600">"+ 1"</span>;
  btn1.<span class="text-amber-600">addEventListener</span>(<span class="text-emerald-600">"click"</span>, increment);

  <span class="text-blue-600">const</span> btn2 = document.<span class="text-amber-600">createElement</span>(<span class="text-emerald-600">"button"</span>);
  btn2.textContent = <span class="text-emerald-600">"− 1"</span>;
  btn2.<span class="text-amber-600">addEventListener</span>(<span class="text-emerald-600">"click"</span>, decrement);

  <span class="text-blue-600">const</span> btn3 = document.<span class="text-amber-600">createElement</span>(<span class="text-emerald-600">"button"</span>);
  btn3.textContent = <span class="text-emerald-600">"Reset"</span>;
  btn3.<span class="text-amber-600">addEventListener</span>(<span class="text-emerald-600">"click"</span>, reset);

  <span class="text-blue-600">const</span> _frag = document
    .<span class="text-amber-600">createDocumentFragment</span>();
  _frag.<span class="text-amber-600">append</span>(p, btn1, btn2, btn3);
  <span class="text-blue-600">return</span> _frag;
}</code></pre>
        </div>
      </div>

    </div>
  </section>
</template>
