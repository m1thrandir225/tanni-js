<script lang="ts">
  import { createSignal } from 'tannijs';

  const [count, setCount] = createSignal(0);
  const [showCode, setShowCode] = createSignal(false);

  function increment() {
    setCount((c) => c + 1);
  }

  function decrement() {
    setCount((c) => c - 1);
  }

  function reset() {
    setCount(0);
  }

  function toggleView() {
    setShowCode((v) => !v);
  }
</script>

<template>
  <section class="bg-gray-50 px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-heading text-center text-3xl tracking-tight text-gray-900 sm:text-4xl">
        Try It Live
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-base leading-relaxed text-gray-500">
        This counter is a real Tanni component running on this page. Toggle to see the source and compiled output.
      </p>

      <div class="mx-auto mt-10 flex justify-center">
        <button
          class="relative inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-1 py-1 shadow-sm"
          @click="toggleView"
        >
          <span
            class="rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
            :class="!showCode() ? 'bg-gray-900 text-white' : 'text-gray-500 hover:text-gray-700'"
          >Live Demo</span>
          <span
            class="rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
            :class="showCode() ? 'bg-gray-900 text-white' : 'text-gray-500 hover:text-gray-700'"
          >View Code</span>
        </button>
      </div>

      <div tn-if="!showCode()" class="mx-auto mt-10 max-w-md">
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <div class="flex items-center gap-2 border-b border-gray-100 bg-gray-50 px-4 py-2.5">
            <span class="h-3 w-3 rounded-full bg-red-400"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
            <span class="h-3 w-3 rounded-full bg-green-400"></span>
            <span class="ml-2 text-xs font-medium text-gray-500">Counter.tanni — running</span>
          </div>
          <div class="p-8 text-center">
            <p class="text-6xl font-semibold tabular-nums text-gray-900">{{ count() }}</p>
            <div class="mt-6 flex justify-center gap-3">
              <button
                class="cursor-pointer rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-indigo-700"
                @click="increment"
              >+ 1</button>
              <button
                class="cursor-pointer rounded-lg bg-gray-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-gray-700"
                @click="decrement"
              >− 1</button>
              <button
                class="cursor-pointer rounded-lg bg-rose-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-rose-700"
                @click="reset"
              >Reset</button>
            </div>
          </div>
        </div>
      </div>

      <div tn-if="showCode()" class="mt-10 grid gap-6 lg:grid-cols-2">
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <div class="flex items-center gap-2 border-b border-gray-100 bg-gray-50 px-4 py-2.5">
            <span class="h-3 w-3 rounded-full bg-red-400"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
            <span class="h-3 w-3 rounded-full bg-green-400"></span>
            <span class="ml-2 text-xs font-medium text-gray-500">Counter.tanni</span>
          </div>
          <pre class="overflow-x-auto p-4 text-[13px] leading-relaxed"><code class="text-gray-800"><span class="text-gray-400">&lt;script lang="ts"&gt;</span>
  <span class="text-blue-600">import</span> { createSignal } <span class="text-blue-600">from</span> <span class="text-emerald-600">'tannijs'</span>;

  <span class="text-blue-600">const</span> [count, setCount] = <span class="text-amber-600">createSignal</span>(<span class="text-violet-600">0</span>);

  <span class="text-blue-600">function</span> <span class="text-amber-600">increment</span>() {
    <span class="text-amber-600">setCount</span>(<span class="text-gray-500">(c) =&gt;</span> c + <span class="text-violet-600">1</span>);
  }

  <span class="text-blue-600">function</span> <span class="text-amber-600">decrement</span>() {
    <span class="text-amber-600">setCount</span>(<span class="text-gray-500">(c) =&gt;</span> c - <span class="text-violet-600">1</span>);
  }

  <span class="text-blue-600">function</span> <span class="text-amber-600">reset</span>() {
